<!-- ╔══════════════════════════════════════════════════════════════════╗ -->
<!-- ║  ScreenshotTool — SettingsWindow.xaml                           ║ -->
<!-- ║  User-facing settings panel. Configurable options:              ║ -->
<!-- ║    • Save folder path (with Browse button)                      ║ -->
<!-- ║    • Hotkey binding (dropdown)                                   ║ -->
<!-- ║    • Auto-start with Windows (checkbox)                         ║ -->
<!-- ║    • Image format (PNG / JPG / BMP)                             ║ -->
<!-- ║    • JPEG quality slider                                         ║ -->
<!-- ║    • Ink color for selection border                              ║ -->
<!-- ╚══════════════════════════════════════════════════════════════════╝ -->

<Window x:Class="ScreenshotTool.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Screenshot Tool — Settings"
        Width="480" Height="600"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Icon="/Assets/app.ico"
        Background="#1E1E1E">

    <Window.Resources>
        <!-- ─── Shared Styles ─────────────────────────────────── -->
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CCCCCC" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#4488FF" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,12,0,6" />
        </Style>

        <!-- ─── Dark Theme: TextBox ────────────────────────────── -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="SelectionBrush" Value="#4488FF"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ─── Dark Theme: ComboBox ───────────────────────────── -->
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                Focusable="False" ClickMode="Press"
                                IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Bd" Background="#2D2D2D"
                                                BorderBrush="#555555" BorderThickness="1"
                                                CornerRadius="3">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition/>
                                                    <ColumnDefinition Width="24"/>
                                                </Grid.ColumnDefinitions>
                                                <Path Grid.Column="1" Data="M0,0 L4,4 8,0"
                                                      Stroke="#AAAAAA" StrokeThickness="1.5"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="BorderBrush" Value="#6699FF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite"
                                Content="{TemplateBinding SelectionBoxItem}"
                                ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                Margin="8,4,28,4"
                                VerticalAlignment="Center" HorizontalAlignment="Left"
                                IsHitTestVisible="False"/>
                            <Popup x:Name="PART_Popup"
                                IsOpen="{TemplateBinding IsDropDownOpen}"
                                Placement="Bottom" AllowsTransparency="True"
                                Focusable="False" PopupAnimation="Slide">
                                <Border Background="#2D2D2D" BorderBrush="#555555" BorderThickness="1"
                                        CornerRadius="3" Margin="0,2,0,0"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                        MinWidth="{TemplateBinding ActualWidth}">
                                    <ScrollViewer CanContentScroll="True">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ─── Dark Theme: ComboBoxItem ───────────────────────── -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3F3F46"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#4488FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ─── Dark Theme: Button ─────────────────────────────── -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="#3C3C3C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#505050"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#6699FF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#4488FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ─── Dark Theme: CheckBox ───────────────────────────── -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border x:Name="CheckBorder" Width="18" Height="18"
                                    Background="#2D2D2D" BorderBrush="#555555" BorderThickness="1"
                                    CornerRadius="3" Margin="0,0,8,0">
                                <Path x:Name="CheckMark" Data="M2,8 L6,12 L14,2"
                                      Stroke="White" StrokeThickness="2" Visibility="Collapsed"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ContentPresenter VerticalAlignment="Center" RecognizesAccessKey="True"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="CheckBorder" Property="Background" Value="#4488FF"/>
                                <Setter TargetName="CheckBorder" Property="BorderBrush" Value="#4488FF"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CheckBorder" Property="BorderBrush" Value="#6699FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ─── Title ──────────────────────────────────────────── -->
        <TextBlock Grid.Row="0"
                   Text="✂️ Screenshot Tool Settings"
                   FontSize="18" FontWeight="Bold"
                   Foreground="White" Margin="0,0,0,8" />

        <!-- ─── Settings Form ──────────────────────────────────── -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- ═══ Save Location Section ══════════════════════ -->
                <TextBlock Text="📁 Save Location" Style="{StaticResource SectionHeader}" />

                <TextBlock Text="Screenshots folder:" Style="{StaticResource LabelStyle}" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="TxtSaveFolder"
                             Grid.Column="0"
                             Background="#2D2D2D" Foreground="White"
                             BorderBrush="#555555" Padding="6,4"
                             FontSize="12" />
                    <Button x:Name="BtnBrowse"
                            Grid.Column="1"
                            Content="Browse..."
                            Click="BtnBrowse_Click"
                            Margin="8,0,0,0" Padding="12,4"
                            Background="#3C3C3C" Foreground="White"
                            BorderBrush="#555555" />
                </Grid>

                <!-- ═══ Hotkey Section ═════════════════════════════ -->
                <TextBlock Text="⌨️ Hotkey" Style="{StaticResource SectionHeader}" />

                <TextBlock Text="Global shortcut (click the box and press your desired key combination):" Style="{StaticResource LabelStyle}" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="TxtHotkey"
                             Grid.Column="0"
                             IsReadOnly="True"
                             Background="#2D2D2D" Foreground="White"
                             BorderBrush="#555555" Padding="6,4"
                             FontSize="13" FontWeight="SemiBold"
                             Cursor="Hand"
                             PreviewKeyDown="TxtHotkey_PreviewKeyDown"
                             GotFocus="TxtHotkey_GotFocus"
                             LostFocus="TxtHotkey_LostFocus" />
                    <Button x:Name="BtnResetHotkey"
                            Grid.Column="1"
                            Content="Reset"
                            Click="BtnResetHotkey_Click"
                            Margin="8,0,0,0" Padding="12,4"
                            Background="#3C3C3C" Foreground="White"
                            BorderBrush="#555555" />
                </Grid>
                <TextBlock x:Name="TxtHotkeyHint"
                           Text="Press a key combination (e.g. Ctrl+Shift+S)"
                           Foreground="#888888" FontSize="11"
                           Margin="0,4,0,0" />
                <TextBlock x:Name="TxtHotkeyWarning"
                           Text="⚠ Win+Shift+S requires disabling built-in Snipping Tool"
                           Foreground="#FFaa44" FontSize="11"
                           Margin="0,4,0,0" Visibility="Collapsed" />

                <!-- ═══ Image Format Section ═══════════════════════ -->
                <TextBlock Text="🖼 Image Format" Style="{StaticResource SectionHeader}" />

                <TextBlock Text="Save as:" Style="{StaticResource LabelStyle}" />
                <ComboBox x:Name="CmbFormat"
                          Background="#2D2D2D" Foreground="White"
                          BorderBrush="#555555" Padding="6,4" FontSize="12"
                          SelectionChanged="CmbFormat_SelectionChanged">
                    <ComboBoxItem Content="PNG (lossless)" />
                    <ComboBoxItem Content="JPG (compressed)" />
                    <ComboBoxItem Content="BMP (uncompressed)" />
                </ComboBox>

                <!-- JPEG Quality (visible only when JPG selected) -->
                <StackPanel x:Name="PnlJpegQuality" Visibility="Collapsed" Margin="0,6,0,0">
                    <TextBlock Style="{StaticResource LabelStyle}">
                        <Run Text="JPEG quality: " />
                        <Run x:Name="TxtJpegValue" Text="90" />
                        <Run Text="%" />
                    </TextBlock>
                    <Slider x:Name="SliderJpeg"
                            Minimum="10" Maximum="100" Value="90"
                            TickFrequency="10" IsSnapToTickEnabled="False"
                            ValueChanged="SliderJpeg_ValueChanged" />
                </StackPanel>

                <!-- ═══ Appearance Section ═════════════════════════ -->
                <TextBlock Text="🎨 Appearance" Style="{StaticResource SectionHeader}" />

                <TextBlock Text="Selection border color:" Style="{StaticResource LabelStyle}" />
                <ComboBox x:Name="CmbInkColor"
                          Background="#2D2D2D" Foreground="White"
                          BorderBrush="#555555" Padding="6,4" FontSize="12">
                    <ComboBoxItem Content="Red" Tag="#FF0000" />
                    <ComboBoxItem Content="Blue" Tag="#4488FF" />
                    <ComboBoxItem Content="Green" Tag="#44FF44" />
                    <ComboBoxItem Content="Yellow" Tag="#FFFF00" />
                    <ComboBoxItem Content="White" Tag="#FFFFFF" />
                    <ComboBoxItem Content="Cyan" Tag="#00FFFF" />
                </ComboBox>

                <!-- ═══ Startup Section ════════════════════════════ -->
                <TextBlock Text="⚙ System" Style="{StaticResource SectionHeader}" />

                <CheckBox x:Name="ChkStartup"
                          Content=" Start with Windows"
                          Foreground="#CCCCCC" FontSize="13"
                          Margin="0,4" />

                <CheckBox x:Name="ChkClipboard"
                          Content=" Copy screenshots to clipboard"
                          Foreground="#CCCCCC" FontSize="13"
                          Margin="0,4" IsChecked="True" />

                <!-- ═══ About Section ══════════════════════════════ -->
                <TextBlock Text="ℹ About" Style="{StaticResource SectionHeader}" />

                <TextBlock Foreground="#CCCCCC" FontSize="12" TextWrapping="Wrap">
                    <Run Text="ScreenshotTool" FontWeight="SemiBold" Foreground="White" />
                    <Run Text=" — A lightweight Snipping Tool replacement" />
                </TextBlock>
                <TextBlock Foreground="#AAAAAA" FontSize="12" Margin="0,4,0,0">
                    <Run Text="Author: " />
                    <Run Text="Tahsan Ahmed Rafat" FontWeight="SemiBold" Foreground="#4488FF" />
                    <Run Text=" (AKA " />
                    <Run Text="PHENOMENAL" FontWeight="Bold" Foreground="#FFaa44" />
                    <Run Text=")" />
                </TextBlock>

            </StackPanel>
        </ScrollViewer>

        <!-- ─── OK / Cancel Buttons ────────────────────────────── -->
        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="BtnOK"
                    Content="OK" Width="80" Padding="0,6"
                    Click="BtnOK_Click"
                    Background="#4488FF" Foreground="White"
                    FontWeight="SemiBold" BorderBrush="#4488FF" />
            <Button x:Name="BtnCancel"
                    Content="Cancel" Width="80" Padding="0,6"
                    Click="BtnCancel_Click" Margin="8,0,0,0"
                    Background="#3C3C3C" Foreground="White"
                    BorderBrush="#555555" />
        </StackPanel>
    </Grid>
</Window>
