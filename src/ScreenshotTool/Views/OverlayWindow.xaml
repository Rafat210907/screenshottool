<!-- ╔══════════════════════════════════════════════════════════════════╗ -->
<!-- ║  ScreenshotTool — OverlayWindow.xaml                            ║ -->
<!-- ║  Fullscreen transparent overlay for screenshot selection.        ║ -->
<!-- ║  Covers all monitors with a dark semi-transparent background.   ║ -->
<!-- ║  Top toolbar with 5 mode buttons (Rectangle, Freeform, Window,  ║ -->
<!-- ║  Fullscreen, Close) styled like Win10 Snip & Sketch.            ║ -->
<!-- ╚══════════════════════════════════════════════════════════════════╝ -->

<Window x:Class="ScreenshotTool.Views.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Cursor="Cross"
        Title="ScreenshotTool Overlay">

    <!-- ─── Main Layout: Canvas + Toolbar ─────────────────────── -->
    <Grid>
        <!-- Layer 0: Dark semi-transparent overlay with selection hole -->
        <Canvas x:Name="OverlayCanvas"
                Background="Transparent"
                MouseLeftButtonDown="OverlayCanvas_MouseLeftButtonDown"
                MouseMove="OverlayCanvas_MouseMove"
                MouseLeftButtonUp="OverlayCanvas_MouseLeftButtonUp">

            <!-- Dark overlay path (full screen with cutout for selection) -->
            <Path x:Name="DarkOverlay" Fill="#80000000" IsHitTestVisible="False">
                <Path.Data>
                    <CombinedGeometry GeometryCombineMode="Exclude">
                        <CombinedGeometry.Geometry1>
                            <RectangleGeometry x:Name="FullScreenGeometry" />
                        </CombinedGeometry.Geometry1>
                        <CombinedGeometry.Geometry2>
                            <RectangleGeometry x:Name="SelectionGeometry"
                                               Rect="0,0,0,0" />
                        </CombinedGeometry.Geometry2>
                    </CombinedGeometry>
                </Path.Data>
            </Path>

            <!-- Selection border rectangle -->
            <Rectangle x:Name="SelectionBorder"
                       Stroke="Red" StrokeThickness="2"
                       Fill="Transparent"
                       Visibility="Collapsed"
                       IsHitTestVisible="False" />

            <!-- Freeform selection polyline -->
            <Polyline x:Name="FreeformLine"
                      Stroke="Red" StrokeThickness="2"
                      Fill="Transparent"
                      Visibility="Collapsed"
                      IsHitTestVisible="False" />

            <!-- Window highlight rectangle -->
            <Rectangle x:Name="WindowHighlight"
                       Stroke="#4488FF" StrokeThickness="3"
                       Fill="#20448AFF"
                       Visibility="Collapsed"
                       IsHitTestVisible="False" />

        </Canvas>

        <!-- Layer 1: Top-center toolbar ────────────────────────── -->
        <Border x:Name="Toolbar"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Margin="0,12,0,0"
                Background="#E0333333"
                CornerRadius="6"
                Padding="4,4,4,4"
                BorderBrush="#555555"
                BorderThickness="1">
            <StackPanel Orientation="Horizontal">

                <!-- Rectangular Snip Button -->
                <Button x:Name="BtnRectangle"
                        Click="BtnRectangle_Click"
                        ToolTip="Rectangular Snip"
                        Style="{StaticResource ToolbarButtonStyle}">
                    <TextBlock Text="⬜" FontSize="18" />
                </Button>

                <!-- Freeform Snip Button -->
                <Button x:Name="BtnFreeform"
                        Click="BtnFreeform_Click"
                        ToolTip="Freeform Snip"
                        Style="{StaticResource ToolbarButtonStyle}">
                    <TextBlock Text="✏" FontSize="18" />
                </Button>

                <!-- Window Snip Button -->
                <Button x:Name="BtnWindow"
                        Click="BtnWindow_Click"
                        ToolTip="Window Snip"
                        Style="{StaticResource ToolbarButtonStyle}">
                    <TextBlock Text="🗔" FontSize="18" />
                </Button>

                <!-- Fullscreen Snip Button -->
                <Button x:Name="BtnFullscreen"
                        Click="BtnFullscreen_Click"
                        ToolTip="Fullscreen Snip"
                        Style="{StaticResource ToolbarButtonStyle}">
                    <TextBlock Text="🖥" FontSize="18" />
                </Button>

                <!-- Separator -->
                <Border Width="1" Background="#666666" Margin="4,2" />

                <!-- Close Button -->
                <Button x:Name="BtnClose"
                        Click="BtnClose_Click"
                        ToolTip="Cancel (Esc)"
                        Style="{StaticResource ToolbarButtonStyle}">
                    <TextBlock Text="✕" FontSize="16" Foreground="#FF6666" />
                </Button>

            </StackPanel>
        </Border>
    </Grid>
</Window>
